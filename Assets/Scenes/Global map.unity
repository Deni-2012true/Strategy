    \u0443\u0441\u0442\u0430\u043D\u0430\u0432\u043B\u0438\u0432\u0430\u0442\u044C
    \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441 \u043C\u0435\u0441\u0442\u043D\u044B\u043C\u0438
    \u0436\u0438\u0442\u0435\u043B\u044F\u043C\u0438, \u043F\u043E\u043A\u0443\u043F\u0430\u0442\u044C
