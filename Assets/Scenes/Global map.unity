  m_text: "\u0426\u0435\u043D\u0442\u0440\u0446\u0438\u0432\u0438\u043B\u0438\u0437\u0430\u0446\u0438\u0438
    \u0432 \u044D\u0442\u0438\u0445 \u0434\u0438\u043A\u0438\u0445 \u043A\u0440\u0430\u044F\u0445.
    \u0417\u0434\u0435\u0441\u044C \u043C\u043E\u0436\u043D\u043E \u043F\u0435\u0440\u0435\u0434\u043E\u0445\u043D\u0443\u0442\u044C
